    "@solana/web3.js": "^1.98.4",
    "bs58": "^4.0.1",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "helius-sdk": "^2.2.2",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/bs58": "^4.0.4",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3"
