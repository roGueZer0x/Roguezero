  "type": "module",
  "scripts": {
    "predev": "npm run build --workspace @roguezero/session-schema && npm run build --workspace @roguezero/runtime-config && npm run build --workspace @roguezero/provider-governor",
    "dev": "tsx watch src/index.ts",
